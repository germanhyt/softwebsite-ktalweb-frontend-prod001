---
import diseno from "@/assets/images/diseño_captar_convertir_crecer.webp?url";
const items = [
  {
    id: 1,
    title: "Optimización",
    desc: "Carga veloz y rendimiento optimizado para una experiencia sin fricciones.",
  },
  {
    id: 2,
    title: "Estructura efectiva",
    desc: "Enfocadas en convertir visitantes en clientes, con una navegación fluida y altamente interactiva.",
  },
  {
    id: 3,
    title: "Escalables",
    desc: "Diseñadas para crecer contigo en el tiempo, permitiéndote integrar fácilmente una tienda, blog, sistema de reservas u otras secciones sin complicaciones.",
  },
  {
    id: 4,
    title: "Navegación intuitiva",
    desc: "Experiencia intuitiva con estructura clara, navegación fluida y contenido fácil de entender.",
  },
  {
    id: 5,
    title: "Diseño adaptable",
    desc: "Diseños que se adaptan a cualquier dispositivo para una experiencia óptima en computadora, tablet o celular.",
  },
];
---

<section class="pt-[4rem] lg:pt-[6rem] px-5 sm:container mx-auto">
  <div class="bg-[#f8f6ff] rounded-4xl py-10 px-4 md:px-12 my-10">
    <h2 class="text-center text-2xl md:text-3xl font-nunito font-medium mb-8">
      Diseñadas para <span class="degradado-c3 font-bold"
        >captar, convertir y crecer</span
      >
    </h2>
    <div class="max-w-6xl mx-auto flex flex-col lg:flex-row items-center gap-8">
      <!-- Imagen -->
      <div class="flex-1 flex justify-center">
        <img
          src={diseno}
          alt="Diseñadas para captar, convertir y crecer"
          class="rounded-[2.5rem] shadow-lg w-full max-w-xs md:max-w-sm object-cover"
        />
      </div>
      <!-- Acordeón -->
      <div class="flex-1 w-full max-w-xl">
        <div id="acordeon-c3">
          {
            items.map((item: any, idx: number) => (
              <div class="border-b border-[#cfc3f7] last:border-b-0">
                <button
                  class="flex justify-between items-center w-full py-5 px-2 text-left font-nunito text-primary-purple-100 text-lg md:text-xl font-bold transition-colors group"
                  aria-expanded={idx === 0 ? "true" : "false"}
                  aria-controls={`panel-c3-${idx}`}
                  data-idx={idx}
                  tabindex="0"
                  style="width:100%"
                >
                  <span class="transition-colors duration-200">
                    {item.title}
                  </span>
                  <span class="text-2xl font-bold select-none transition-transform duration-300 group-hover:scale-125">
                    {idx === 0 ? "-" : "+"}
                  </span>
                </button>
                <div
                  id={`panel-c3-${idx}`}
                  class={`overflow-hidden transition-c3-panel ${idx === 0 ? "max-h-32 opacity-100" : "max-h-0 opacity-0"}`}
                >
                  <p class="text-black text-sm md:text-base font-nunito px-2 pb-4 pt-1">
                    {item.desc}
                  </p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .text-primary-purple-100 {
    color: #7b3ff2;
  }

  .shadow-lg {
    box-shadow: 0 10px 24px 0 rgba(123, 63, 242, 0.08);
  }
  .font-nunito {
    font-family: "Nunito", sans-serif;
  }

  .select-none {
    user-select: none;
  }

  .transition-c3-panel {
    transition:
      max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1),
      opacity 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }
</style>

<script>
  // Acordeón solo Astro/JS
  document.addEventListener("DOMContentLoaded", function () {
    const root = document.getElementById("acordeon-c3");
    if (!root) return;
    const buttons = root.querySelectorAll("button[data-idx]");
    const panels = root.querySelectorAll("div[id^='panel-c3-']");
    let openIdx = 0;

    function open(idx: number) {
      if (openIdx === idx) return;
      // Cierra el anterior
      buttons[openIdx].setAttribute("aria-expanded", "false");
      const prevSpan = buttons[openIdx].querySelector("span.text-2xl");
      if (prevSpan) prevSpan.textContent = "+";
      panels[openIdx].classList.remove("max-h-32", "opacity-100");
      panels[openIdx].classList.add("max-h-0", "opacity-0");

      // Abre el nuevo
      buttons[idx].setAttribute("aria-expanded", "true");
      const newSpan = buttons[idx].querySelector("span.text-2xl");
      if (newSpan) newSpan.textContent = "-";
      panels[idx].classList.remove("max-h-0", "opacity-0");
      panels[idx].classList.add("max-h-32", "opacity-100");

      openIdx = idx;
    }

    // Inicial: solo el primero abierto
    open(0);

    buttons.forEach((btn, idx) => {
      btn.addEventListener("click", () => open(idx));
      btn.addEventListener("keydown", (e: any) => {
        if (e.key === "Enter" || e.key === " ") {
          e.preventDefault();
          open(idx);
        }
      });
    });
  });
</script>
