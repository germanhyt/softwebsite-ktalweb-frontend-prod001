# Clave de API de DeepSeek (https://api.deepseek.com)
DEEPSEEK_API_KEY=

# Opcional: URL del endpoint chat/completions (compatible OpenAI)
# DEEPSEEK_API_URL=https://api.deepseek.com/chat/completions

# Opcional: modelo (ej. deepseek-chat)
# DEEPSEEK_MODEL=deepseek-chat

# Opcional: timeout en ms hacia DeepSeek (por defecto ~8500; en Vercel Hobby el límite total ~10s)
# CHAT_UPSTREAM_MS=8500
