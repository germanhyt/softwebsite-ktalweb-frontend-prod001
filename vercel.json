{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "src/pages/api/download-brochure.ts": {
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/(.*).pdf",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/pdf"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "routes": [
    {
      "src": "/brochure_ktalweb.pdf",
      "dest": "/brochure_ktalweb.pdf"
    },
    {
      "src": "/api/download-brochure",
      "dest": "/api/download-brochure"
    }
  ]
}
